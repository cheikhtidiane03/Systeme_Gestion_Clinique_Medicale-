<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="sn.cheikh.gestion_clinique_medicale.Controller.UtilisateurController"
      styleClass="view-root" spacing="20"
      stylesheets="@../css/style.css">

    <!-- EN-TÊTE -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS" spacing="3">
            <Label text="Gestion des Utilisateurs" styleClass="view-titre"/>
            <Label text="Créer, modifier et désactiver les comptes du personnel"
                   style="-fx-font-size:12px; -fx-text-fill:#64748B;"/>
        </VBox>
        <Button text="+ Nouvel utilisateur" onAction="#nouveau"
                styleClass="btn-primary" style="-fx-padding: 11 20;"/>
    </HBox>

    <!-- TABLEAU PLEINE LARGEUR -->
    <VBox styleClass="table-card" spacing="12" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label text="Liste des utilisateurs" styleClass="card-titre" HBox.hgrow="ALWAYS"/>
        </HBox>
        <Separator/>
        <HBox spacing="8">
            <Button text="Modifier"  onAction="#modifier"  styleClass="btn-secondary"/>
            <Button text="Supprimer" onAction="#supprimer" styleClass="btn-danger"/>
        </HBox>
        <Label fx:id="lblMessage" styleClass="msg-info" wrapText="true"/>
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"     text="ID"     prefWidth="60"/>
                <TableColumn fx:id="colNom"    text="Nom"    prefWidth="160"/>
                <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="160"/>
                <TableColumn fx:id="colLogin"  text="Login"  prefWidth="160"/>
                <TableColumn fx:id="colRole"   text="Rôle"   prefWidth="150"/>
                <TableColumn fx:id="colActif"  text="Actif"  prefWidth="90"/>
            </columns>
            <placeholder><Label text="Aucun utilisateur enregistré"/></placeholder>
        </TableView>
    </VBox>
</VBox>