<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="sn.cheikh.gestion_clinique_medicale.Controller.RendezVousController"
      styleClass="view-root" spacing="20"
      stylesheets="@../css/style.css">

    <!-- EN-TÊTE -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS" spacing="3">
            <Label text="Gestion des Rendez-vous" styleClass="view-titre"/>
            <Label text="Planifier et suivre les rendez-vous des patients"
                   style="-fx-font-size:12px; -fx-text-fill:#64748B;"/>
        </VBox>
        <Button fx:id="btnNouveauBar" text="+ Nouveau RDV" onAction="#nouveau"
                styleClass="btn-primary" style="-fx-padding: 11 20;"/>
    </HBox>

    <!-- FILTRES -->
    <HBox spacing="10" styleClass="search-bar" alignment="CENTER_LEFT">
        <Button text="RDV du jour"  onAction="#afficherDuJour" styleClass="btn-info"/>
        <Button text="Tous les RDV" onAction="#chargerTous"    styleClass="btn-secondary"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label text="Cliquer sur une ligne pour la sélectionner"
               style="-fx-font-size:11px; -fx-text-fill:#94A3B8;"/>
    </HBox>

    <!-- TABLEAU PLEINE LARGEUR -->
    <VBox styleClass="table-card" spacing="12" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label text="Liste des rendez-vous" styleClass="card-titre" HBox.hgrow="ALWAYS"/>
        </HBox>
        <Separator/>
        <HBox spacing="8">
            <Button text="Modifier"    onAction="#modifier" styleClass="btn-secondary"/>
            <Button text="Annuler RDV" onAction="#annuler"  styleClass="btn-danger"/>
        </HBox>
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"        text="ID"         prefWidth="60"/>
                <TableColumn fx:id="colPatient"   text="Patient"    prefWidth="180"/>
                <TableColumn fx:id="colMedecin"   text="Médecin"    prefWidth="180"/>
                <TableColumn fx:id="colDateHeure" text="Date/Heure" prefWidth="160"/>
                <TableColumn fx:id="colMotif"     text="Motif"      prefWidth="200"/>
                <TableColumn fx:id="colStatut"    text="Statut"     prefWidth="120"/>
            </columns>
            <placeholder><Label text="Aucun rendez-vous trouvé"/></placeholder>
        </TableView>
    </VBox>
</VBox>