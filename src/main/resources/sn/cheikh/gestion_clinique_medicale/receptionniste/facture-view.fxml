<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="sn.cheikh.gestion_clinique_medicale.Controller.FactureController"
      styleClass="view-root" spacing="20"
      stylesheets="@../css/style.css">

    <!-- EN-TÊTE -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS" spacing="3">
            <Label text="Gestion des Factures" styleClass="view-titre"/>
            <Label text="Émettre, suivre et imprimer les factures des consultations"
                   style="-fx-font-size:12px; -fx-text-fill:#64748B;"/>
        </VBox>
        <Button text="+ Nouvelle facture" onAction="#nouveau"
                styleClass="btn-primary" style="-fx-padding: 11 20;"/>
    </HBox>

    <!-- FILTRES -->
    <HBox spacing="10" styleClass="search-bar" alignment="CENTER_LEFT">
        <Button text="Impayées" onAction="#filtrerNonPaye" styleClass="btn-danger"/>
        <Button text="Toutes"   onAction="#afficherTout"   styleClass="btn-secondary"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Label text="Sélectionner une ligne pour agir dessus"
               style="-fx-font-size:11px; -fx-text-fill:#94A3B8;"/>
    </HBox>

    <!-- TABLEAU PLEINE LARGEUR -->
    <VBox styleClass="table-card" spacing="12" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label text="Liste des factures" styleClass="card-titre" HBox.hgrow="ALWAYS"/>
        </HBox>
        <Separator/>
        <HBox spacing="8">
            <Button text="Marquer payée"  onAction="#marquerPaye"     styleClass="btn-success"/>
            <Button text="Imprimer PDF"   onAction="#imprimerFacture"  styleClass="btn-info"/>
            <Button text="Modifier"       onAction="#modifier"         styleClass="btn-secondary"/>
        </HBox>
        <Label fx:id="lblMessage" styleClass="msg-info" wrapText="true"/>
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"      text="ID"      prefWidth="60"/>
                <TableColumn fx:id="colPatient" text="Patient" prefWidth="200"/>
                <TableColumn fx:id="colDate"    text="Date"    prefWidth="150"/>
                <TableColumn fx:id="colMontant" text="Montant" prefWidth="130"/>
                <TableColumn fx:id="colMode"    text="Mode"    prefWidth="140"/>
                <TableColumn fx:id="colStatut"  text="Statut"  prefWidth="120"/>
            </columns>
            <placeholder><Label text="Aucune facture trouvée"/></placeholder>
        </TableView>
    </VBox>
</VBox>