<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="sn.cheikh.gestion_clinique_medicale.Controller.FactureController"
      styleClass="view-root" spacing="16"
      stylesheets="@../css/style.css">

    <Label text="Gestion des Factures" styleClass="view-titre"/>

    <HBox spacing="8" styleClass="search-bar">
        <Button text="Non payees" onAction="#filtrerNonPaye" styleClass="btn-danger"/>
        <Button text="Toutes"     onAction="#afficherTout"   styleClass="btn-secondary"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="Nouvelle"   onAction="#nouveau"        styleClass="btn-primary"/>
    </HBox>

    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <ScrollPane fitToWidth="true" prefWidth="340" minWidth="340"
                    style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-color:transparent;">
            <VBox styleClass="form-card" spacing="10">
                <Label text="Generer une facture" styleClass="card-titre"/>
                <Separator/>
                <Label text="Consultation *" styleClass="form-label"/>
                <ComboBox fx:id="cbConsultation" promptText="Selectionner une consultation"
                          maxWidth="Infinity" styleClass="form-input"/>
                <Label text="Montant (FCFA) *" styleClass="form-label"/>
                <TextField fx:id="tfMontant" promptText="Ex: 15000" styleClass="form-input"/>
                <Label text="Mode de paiement *" styleClass="form-label"/>
                <ComboBox fx:id="cbModePaiement" promptText="Selectionner le mode"
                          maxWidth="Infinity" styleClass="form-input"/>
                <Label fx:id="lblMessage" styleClass="msg-info" wrapText="true"/>
                <Button text="Generer la facture" onAction="#genererFacture"
                        styleClass="btn-primary" maxWidth="Infinity"/>
                <Separator/>
                <Button text="Marquer comme payee" onAction="#marquerPaye"
                        styleClass="btn-success" maxWidth="Infinity"/>
                <Button text="Imprimer PDF" onAction="#imprimerFacture"
                        styleClass="btn-info" maxWidth="Infinity"/>
                <Button text="Nouveau" onAction="#nouveau"
                        styleClass="btn-secondary" maxWidth="Infinity"/>
            </VBox>
        </ScrollPane>

        <VBox styleClass="table-card" spacing="10" HBox.hgrow="ALWAYS">
            <Label text="Liste des factures" styleClass="card-titre"/>
            <Separator/>
            <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"      text="ID"      prefWidth="50"/>
                    <TableColumn fx:id="colPatient" text="Patient" prefWidth="160"/>
                    <TableColumn fx:id="colDate"    text="Date"    prefWidth="130"/>
                    <TableColumn fx:id="colMontant" text="Montant" prefWidth="110"/>
                    <TableColumn fx:id="colMode"    text="Mode"    prefWidth="120"/>
                    <TableColumn fx:id="colStatut"  text="Statut"  prefWidth="100"/>
                </columns>
                <placeholder><Label text="Aucune facture"/></placeholder>
            </TableView>
        </VBox>
    </HBox>
</VBox>