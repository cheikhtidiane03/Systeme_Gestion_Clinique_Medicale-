<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="sn.cheikh.gestion_clinique_medicale.Controller.ConsultationController"
      styleClass="view-root" spacing="20"
      stylesheets="@../css/style.css">

    <!-- EN-TÊTE -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS" spacing="3">
            <Label text="Gestion des Consultations" styleClass="view-titre"/>
            <Label text="Enregistrer les consultations et générer les ordonnances"
                   style="-fx-font-size:12px; -fx-text-fill:#64748B;"/>
        </VBox>
        <!-- Bouton Nouveau masqué pour médecin via controller -->
        <Button fx:id="btnNouveau" text="+ Nouvelle consultation" onAction="#nouveau"
                styleClass="btn-primary" style="-fx-padding: 11 20;"/>
    </HBox>

    <!-- TABLEAU PLEINE LARGEUR -->
    <VBox styleClass="table-card" spacing="12" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Label text="Historique des consultations" styleClass="card-titre" HBox.hgrow="ALWAYS"/>
        </HBox>
        <Separator/>
        <HBox spacing="8">
            <Button fx:id="btnModifier"   text="Modifier"            onAction="#modifier"         styleClass="btn-secondary"/>
            <Button text="Ordonnance PDF" onAction="#genererOrdonnance" styleClass="btn-info"/>
        </HBox>
        <Label fx:id="lblMessage" styleClass="msg-info" wrapText="true"/>
        <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"         text="ID"         prefWidth="60"/>
                <TableColumn fx:id="colPatient"    text="Patient"    prefWidth="180"/>
                <TableColumn fx:id="colMedecin"    text="Médecin"    prefWidth="180"/>
                <TableColumn fx:id="colDate"       text="Date"       prefWidth="150"/>
                <TableColumn fx:id="colDiagnostic" text="Diagnostic" prefWidth="280"/>
                <TableColumn fx:id="colRdv"        text="RDV lié"    prefWidth="130"/>
            </columns>
            <placeholder><Label text="Aucune consultation enregistrée"/></placeholder>
        </TableView>
    </VBox>
</VBox>