<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="sn.cheikh.gestion_clinique_medicale.Controller.ConsultationController"
      styleClass="view-root" spacing="16"
      stylesheets="@../css/style.css">

    <Label text="Gestion des Consultations" styleClass="view-titre"/>

    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- FORMULAIRE SCROLLABLE -->
        <ScrollPane fitToWidth="true" prefWidth="340" minWidth="340"
                    style="-fx-background-color:transparent; -fx-background:transparent; -fx-border-color:transparent;">

            <VBox styleClass="form-card" spacing="10">

                <Label text="Nouvelle consultation" styleClass="card-titre"/>
                <Separator/>

                <Label text="Patient *" styleClass="form-label"/>
                <ComboBox fx:id="cbPatient" promptText="Selectionner un patient"
                          maxWidth="Infinity" styleClass="form-input"/>

                <Label text="Medecin *" styleClass="form-label"/>
                <ComboBox fx:id="cbMedecin" promptText="Selectionner un medecin"
                          maxWidth="Infinity" styleClass="form-input"/>

                <Label text="Rendez-vous lie" styleClass="form-label"/>
                <ComboBox fx:id="cbRendezVous" promptText="Selectionner un RDV (optionnel)"
                          maxWidth="Infinity" styleClass="form-input"/>

                <Label text="Diagnostic *" styleClass="form-label"/>
                <TextArea fx:id="taDiagnostic"
                          promptText="Diagnostic..."
                          prefRowCount="3"
                          styleClass="form-input"
                          wrapText="true"/>

                <Label text="Observations" styleClass="form-label"/>
                <TextArea fx:id="taObservations"
                          promptText="Observations..."
                          prefRowCount="3"
                          styleClass="form-input"
                          wrapText="true"/>

                <Label text="Prescription" styleClass="form-label"/>
                <TextArea fx:id="taPrescription"
                          promptText="Medicaments prescrits..."
                          prefRowCount="3"
                          styleClass="form-input"
                          wrapText="true"/>

                <Label fx:id="lblMessage" styleClass="msg-info" wrapText="true"/>

                <HBox spacing="8">
                    <Button text="Enregistrer"
                            onAction="#sauvegarder"
                            styleClass="btn-primary"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"/>

                    <Button text="Nouveau"
                            onAction="#nouveau"
                            styleClass="btn-secondary"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"/>
                </HBox>

                <Button text="Generer Ordonnance PDF"
                        onAction="#genererOrdonnance"
                        styleClass="btn-info"
                        maxWidth="Infinity"/>

            </VBox>
        </ScrollPane>

        <!-- TABLEAU -->
        <VBox styleClass="table-card" spacing="10" HBox.hgrow="ALWAYS">

            <Label text="Historique des consultations" styleClass="card-titre"/>
            <Separator/>

            <TableView fx:id="tableView" VBox.vgrow="ALWAYS">

                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colPatient" text="Patient" prefWidth="160"/>
                    <TableColumn fx:id="colMedecin" text="Medecin" prefWidth="160"/>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="140"/>
                    <TableColumn fx:id="colDiagnostic" text="Diagnostic" prefWidth="200"/>
                </columns>

                <placeholder>
                    <Label text="Aucune consultation enregistree"/>
                </placeholder>

            </TableView>

        </VBox>

    </HBox>

</VBox>